[Unit]
Description=CoreRP Persistent Narrative Runtime
After=network.target

[Service]
Type=simple
User=kelebituo
WorkingDirectory=/home/kelebituo/corerp
ExecStart=/home/kelebituo/corerp/corerp serve \
  -data /home/kelebituo/corerp/data \
  -characters /home/kelebituo/corerp/characters \
  -llm-url $LLM_URL \
  -llm-key $LLM_API_KEY \
  -llm-model $LLM_MODEL
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=LLM_URL=https://gcli.ggchan.dev/v1
Environment=LLM_MODEL=gemini-3-flash-preview
Environment=LLM_API_KEY=

# Fill in LLM_API_KEY above or use a separate env file:
# EnvironmentFile=/home/kelebituo/corerp/.env

# Smoke check hint: /home/kelebituo/corerp/deploy/smoke-check.sh

[Install]
WantedBy=multi-user.target
